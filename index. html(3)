                lines.forEach(line => {
                    if (/^[০-৯]+[.)\]】:]/.test(line) || /^[-•●▪️▸►]/.test(line)) {
                        const clean = line.replace(/^[০-৯.)\]】：\-\s•●▪️▸►]+/, '').trim();
                        if (clean.length > 3) {
                            const isGarbage = garbagePhrases.some(g => clean.toLowerCase().includes(g.toLowerCase()));
                            if (!isGarbage) topics.push(clean);
                        }
                    }
                });
            }

            if (topics.length === 0) {
                const sentences = text.split(/[।\n]+/).map(s => s.trim()).filter(s => s.length > 8);
                sentences.forEach(s => {
                    const isGarbage = garbagePhrases.some(g => s.toLowerCase().includes(g.toLowerCase()));
